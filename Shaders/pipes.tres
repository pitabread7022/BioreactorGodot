code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform vec4 pipeColor2 : source_color = vec4(0.337330, 0.879215, 0.823918, 1.000000);
uniform bool containsFlow = true;
uniform int fluct = 5;
uniform vec4 pipeColor : source_color = vec4(0.358200, 0.066440, 0.130746, 1.000000);
uniform float metallic = 0.80000001192093;
uniform float roughness = 0.10000000149012;



void fragment() {
// ColorParameter:5
	vec4 n_out5p0 = pipeColor2;


// BooleanParameter:3
	bool n_out3p0 = containsFlow;


// Input:7
	float n_out7p0 = TIME;


// FloatFunc:8
