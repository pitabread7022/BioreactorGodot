// FloatOp:10
	float n_out10p0 = pow(n_out7p0, float(n_out12p0));


// FloatFunc:11
	float n_out11p0 = cos(n_out10p0);


// FloatOp:14
	float n_out14p0 = n_out8p0 + n_out11p0;


// MultiplyAdd:13
	float n_in13p2 = 0.00000;
	float n_out13p0 = fma((n_out3p0 ? 1.0 : 0.0), n_out14p0, n_in13p2);


// VectorCompose:9
	float n_in9p1 = 0.00000;
	float n_in9p2 = 0.00000;
	vec3 n_out9p0 = vec3(n_out13p0, n_in9p1, n_in9p2);


// ColorParameter:2
	vec4 n_out2p0 = pipeColor;


// MultiplyAdd:4
	vec3 n_out4p0 = fma(vec3(n_out5p0.xyz), n_out9p0, vec3(n_out2p0.xyz));


// FloatParameter:16
	float n_out16p0 = metallic;


// FloatParameter:15
	float n_out15p0 = roughness;


// Output:0
	ALBEDO = n_out4p0;
	METALLIC = n_out16p0;
	ROUGHNESS = n_out15p0;


}
