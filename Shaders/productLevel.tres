code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform vec4 ColorParameter : source_color = vec4(0.070588, 1.000000, 1.000000, 1.000000);
uniform bool blink = false;



void fragment() {
// ColorParameter:2
	vec4 n_out2p0 = ColorParameter;


// BooleanParameter:4
	bool n_out4p0 = blink;


// VectorCompose:9
	vec3 n_out9p0 = vec3((n_out4p0 ? 1.0 : 0.0), (n_out4p0 ? 1.0 : 0.0), (n_out4p0 ? 1.0 : 0.0));


// Input:3
	float n_out3p0 = TIME;


// FloatConstant:7
	float n_out7p0 = 0.000000;


// MultiplyAdd:6
	float n_out6p0 = fma(n_out3p0, n_out7p0, n_out7p0);


// FloatFunc:5
	float n_out5p0 = sin(n_out6p0);


// FloatFunc:12
	float n_out12p0 = cos(n_out6p0);


// MultiplyAdd:13
	float n_in13p1 = 17.00000;
	float n_in13p2 = 20.00000;
	float n_out13p0 = fma(n_out6p0, n_in13p1, n_in13p2);


// VectorCompose:11
	vec3 n_out11p0 = vec3(n_out5p0, n_out12p0, n_out13p0);


// MultiplyAdd:10
	vec3 n_in10p2 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_out10p0 = fma(n_out9p0, n_out11p0, n_in10p2);


// MultiplyAdd:8
	vec3 n_in8p2 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_out8p0 = fma(vec3(n_out2p0.xyz), n_out10p0, n_in8p2);


// Output:0
	ALBEDO = vec3(n_out2p0.xyz);
	EMISSION = n_out8p0;


}
